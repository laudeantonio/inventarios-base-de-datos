      "parameters": {
        "jsCode": "const uniqueNames = new Set();\nconst result = [];\n\n// Usamos .all() para ver los 12 registros de entrada\nconst items = $input.all();\n\nfor (let i = 0; i < items.length; i++) {\n  const name = items[i].json.nombre;\n  \n  if (name && !uniqueNames.has(name)) {\n    uniqueNames.add(name);\n    \n    result.push({\n      json: { nombre: name },\n      // Esto arregla el error de \"Paired item\"\n      pairedItem: { item: i } \n    });\n  }\n}\n\nreturn result;\n\nreturn result;"
      },
