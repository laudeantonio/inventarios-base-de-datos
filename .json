    {
      "parameters": {
        "jsCode": "// 1. Mapa de conversión\nconst mapa = {\n    \"Facturación electrónica\": 1,\n    \"Contabilidad\": 2,\n    \"Inventarios\": 3,\n    \"Informes\": 4,\n    \"Nómina\": 5,\n    \"CXC\": 6,\n    \"CXP\": 7,\n    \"Informes avanzados\": 8,\n    \"API\": 9,\n    \"Soporte dedicado\": 10,\n    \"SLA garantizado\": 11,\n    \"Declaraciones\": 12,\n    \"POS\": 13\n};\n\nconst entrada = $('Registro de producto').first().json.Modulo;\nconst results = [];\n\n// 2. Si es una lista, creamos un objeto por cada ID\nif (Array.isArray(entrada)) {\n    entrada.forEach(nombre => {\n        const id = mapa[nombre];\n        if (id !== undefined) {\n            results.push({ json: { modulo_id: id } });\n        }\n    });\n} else {\n    // Si es uno solo\n    const id = mapa[entrada];\n    if (id !== undefined) {\n        results.push({ json: { modulo_id: id } });\n    }\n}\n\n// 3. Importante: n8n procesará cada elemento de este array por separado\nreturn results;"
      },
